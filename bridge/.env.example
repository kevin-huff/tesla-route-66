# Secret / environment overrides for the Route 66 bridge.
# Anything set here WINS over config.json so credentials stay out of the committed file.
# Copy to `.env` and fill in. The bridge auto-loads `.env` at boot (no dotenv dependency).

# Run mode: demo | live   (overrides config.mode; demo is the default and needs no car)
# R66_MODE=demo

# Network
# R66_PORT=8787

# TeslaMate Postgres (live mode)
# R66_PG_PASSWORD=changeme

# TeslaMate MQTT broker (live mode)
# R66_MQTT_USERNAME=
# R66_MQTT_PASSWORD=
