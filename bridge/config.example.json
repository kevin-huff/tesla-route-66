{
  "mode": "demo",

  "server": {
    "host": "0.0.0.0",
    "port": 8787,
    "heartbeatMs": 10000,
    "overlaysDir": "../overlays"
  },

  "units": {
    "distance": "mi",
    "speed": "mph",
    "temp": "F",
    "elevation": "ft"
  },

  "vehicle": {
    "carId": 1,
    "name": "Kevin's Tesla"
  },

  "trip": {
    "name": "The Kevin Show - Route 66 Loop",
    "totalLegs": 6,
    "timezone": "America/Chicago",
    "landmarksPath": "../planning/landmarks.json",
    "legsPath": "../config/legs.json",
    "routeGeometryPath": "../config/route-geometry.json",
    "odometerBaselineKm": null,
    "elevationBaselineM": null,
    "statesPlanned": ["MO", "KS", "OK", "TX", "NM", "AZ"],
    "avgIceTankRangeMi": 29,
    "iceMpg": 25,
    "gasPriceUsdPerGal": 3.2
  },

  "thresholds": {
    "lowBatteryPct": 15,
    "criticalBatteryPct": 10,
    "lowBatteryRearmPct": 3,
    "scMarginWarnMi": 40,
    "speedSpikeMph": 25,
    "speedMaxPlausibleMph": 110
  },

  "transmissions": {
    "source": "llm",
    "intervalSec": 300,
    "kickoffSec": 20,
    "drivingOnly": true,
    "minMoveMi": 5,
    "recentPlaces": 6,
    "llm": {
      "baseUrl": "http://localhost:8484/v1",
      "apiKey": "",
      "model": "claude-sonnet-4-5",
      "temperature": null,
      "maxTokens": 220,
      "timeoutMs": 30000
    }
  },

  "mqtt": {
    "url": "mqtt://teslamate.lan:1883",
    "username": null,
    "password": null,
    "topicBase": "teslamate/cars/1",
    "reconnectMs": 4000
  },

  "postgres": {
    "host": "teslamate.lan",
    "port": 5432,
    "database": "teslamate",
    "user": "teslamate",
    "password": "CHANGE_ME",
    "ssl": false,
    "pollIntervalSec": 60
  },

  "demo": {
    "tickMs": 250,
    "timeCompression": 120,
    "loop": true,
    "standbyDwellSec": 8,
    "startLeg": 1,
    "cruiseMph": 64,
    "startBatteryPct": 92
  },

  "ride": {
    "enabled": true,
    "authToken": "CHANGE_ME",
    "storage": "auto",
    "pgSchema": "ride_tracker",
    "timezone": "America/Chicago",
    "statsTickSec": 5,
    "shiftStartsAt": "9:00 PM",
    "privacy": {
      "lat": null,
      "lng": null,
      "radiusM": 800
    },
    "heat": {
      "binM": 250
    },
    "path": {
      "minMoveM": 40,
      "maxPoints": 4000
    },
    "demo": {
      "center": { "lat": 37.2090, "lng": -93.2923 },
      "home": { "lat": 37.1885, "lng": -93.3110 },
      "tickMs": 250,
      "rideSecMin": 18,
      "rideSecMax": 40,
      "idleSecMin": 6,
      "idleSecMax": 14,
      "ridesPerShift": 8
    }
  }
}
